rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: players
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, max 100 chars)
    //   - phone: string (required, max 20 chars)
    //   - efootballId: string (required, max 50 chars)
    //   - paymentScreenshotUrl: string (optional, max 500 chars)
    //   - status: string (required, 'pending', 'approved', 'banned')
    //   - group: string (required, 'A', 'B', 'None')
    //   - points: number (required)
    //   - gd: number (required)
    //   - played: number (required)
    //   - wins: number (required)
    //   - draws: number (required)
    //   - losses: number (required)
    //   - seed: number (optional)
    //   - createdAt: string (required)
    //
    // Collection: matches
    // Document ID: auto-generated
    // Fields:
    //   - homePlayerId: string (required)
    //   - homePlayerName: string (required)
    //   - awayPlayerId: string (required)
    //   - awayPlayerName: string (required)
    //   - homeScore: number (required)
    //   - awayScore: number (required)
    //   - stage: string (required, 'group', 'quarter-final', 'semi-final', 'final')
    //   - status: string (required, 'scheduled', 'completed')
    //   - group: string (required, 'A', 'B', 'None')
    //   - matchIndex: number (optional)
    //
    // Collection: settings
    // Document ID: 'global'
    // Fields:
    //   - rules: string (required, max 5000 chars)
    //   - activeStage: string (required, 'registration', 'draw', 'groups', 'knockout')
    //
    // Collection: users
    // Document ID: user uid
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin')
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "rboopathi1045@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !('field' in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidPlayer() {
      let allowedFields = ['name', 'phone', 'efootballId', 'paymentScreenshotUrl', 'status', 'group', 'points', 'gd', 'played', 'wins', 'draws', 'losses', 'seed', 'createdAt'];
      return hasOnlyAllowedFields(allowedFields) &&
             isValidString('name', 1, 100) &&
             isValidString('phone', 1, 20) &&
             isValidString('efootballId', 1, 50) &&
             isValidOptionalString('paymentScreenshotUrl', 0, 500) &&
             request.resource.data.status in ['pending', 'approved', 'banned'] &&
             request.resource.data.group in ['A', 'B', 'None'] &&
             request.resource.data.points is number &&
             request.resource.data.gd is number &&
             request.resource.data.played is number &&
             request.resource.data.wins is number &&
             request.resource.data.draws is number &&
             request.resource.data.losses is number &&
             (!('seed' in request.resource.data) || request.resource.data.seed is number) &&
             request.resource.data.createdAt is string;
    }

    function isValidMatch() {
      let allowedFields = ['homePlayerId', 'homePlayerName', 'awayPlayerId', 'awayPlayerName', 'homeScore', 'awayScore', 'stage', 'status', 'group', 'matchIndex'];
      return hasOnlyAllowedFields(allowedFields) &&
             isValidString('homePlayerId', 1, 100) &&
             isValidString('homePlayerName', 1, 100) &&
             isValidString('awayPlayerId', 1, 100) &&
             isValidString('awayPlayerName', 1, 100) &&
             request.resource.data.homeScore is number &&
             request.resource.data.awayScore is number &&
             request.resource.data.stage in ['group', 'quarter-final', 'semi-final', 'final'] &&
             request.resource.data.status in ['scheduled', 'completed'] &&
             request.resource.data.group in ['A', 'B', 'None'] &&
             (!('matchIndex' in request.resource.data) || request.resource.data.matchIndex is number);
    }

    function isValidSettings() {
      let allowedFields = ['rules', 'activeStage', 'entryFee', 'paymentNumber', 'paymentQrUrl'];
      return hasOnlyAllowedFields(allowedFields) &&
             isValidString('rules', 0, 5000) &&
             request.resource.data.activeStage in ['registration', 'draw', 'groups', 'knockout'] &&
             isValidOptionalString('entryFee', 0, 50) &&
             isValidOptionalString('paymentNumber', 0, 50) &&
             isValidOptionalString('paymentQrUrl', 0, 500);
    }

    function isValidUser() {
      let allowedFields = ['email', 'role'];
      return hasOnlyAllowedFields(allowedFields) &&
             isValidString('email', 1, 100) &&
             request.resource.data.role == 'admin';
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /players/{playerId} {
      // Anyone can read approved players for public display
      // Admin can read all
      allow read: if resource.data.status == 'approved' || isAdmin();
      // Anyone can create a pending player (registration)
      allow create: if isValidPlayer() && request.resource.data.status == 'pending';
      // Only admin can update or delete
      allow update: if isAdmin() && isValidPlayer();
      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      // Anyone can read matches
      allow read: if true;
      // Only admin can create, update, delete
      allow create: if isAdmin() && isValidMatch();
      allow update: if isAdmin() && isValidMatch();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      // Anyone can read settings
      allow read: if true;
      // Only admin can create, update, delete
      allow create: if isAdmin() && isValidSettings();
      allow update: if isAdmin() && isValidSettings();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Admin can read all users
      allow read: if isAdmin();
      // Only admin can create or update users
      allow create: if isAdmin() && isValidUser();
      allow update: if isAdmin() && isValidUser();
      allow delete: if isAdmin();
    }
  }
}
